# =============================================================================
# EduGrade Server — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# ---- Server ---------------------------------------------------------------
PORT=5000
NODE_ENV=development

# ---- Database (use DATABASE_URL or individual PG* vars) --------------------
# Connection string (preferred):
DATABASE_URL=postgres://postgres:postgres@localhost:5432/edugrade

# Individual connection params (fallback if DATABASE_URL is unset):
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=edugrade

# Set to "true" to enable SSL for the database connection (e.g. Supabase, Railway)
PGSSL=false

# ---- JWT ------------------------------------------------------------------
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
JWT_EXPIRES_IN=7d

# ---- Groq API (replaces Anthropic/Claude) ---------------------------------
# Get a free API key at https://console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxx
GROQ_MODEL=llama-3.3-70b-versatile

# ---- OCR Service ----------------------------------------------------------
OCR_SERVICE_URL=http://localhost:8001

# ---- Uploads --------------------------------------------------------------
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=10

# ---- CORS -----------------------------------------------------------------
# Frontend URL (origin allowed by CORS)
CLIENT_ORIGIN=http://localhost:5173
CLIENT_URL=http://localhost:5173           # Alias for CLIENT_ORIGIN

# For production builds served via Nginx, the API proxy usually means:
# CLIENT_ORIGIN=http://localhost:3000
# CLIENT_URL=http://localhost:3000

# ---- Redis (optional — for future job queues) -----------------------------
REDIS_URL=redis://localhost:6379
